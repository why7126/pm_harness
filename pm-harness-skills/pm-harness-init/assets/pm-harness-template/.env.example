# ==============================================================================
# Tile Info Platform - Environment Variables Example
# ==============================================================================
# 复制本文件为 .env 后按需修改；禁止提交真实 .env、密钥、生产地址。

APP_NAME=tile-info-platform
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-local-env

# 端口策略：容器内端口固定，宿主机端口可配置，避免多项目冲突。
HOST_PORT_BACKEND=8000
HOST_PORT_WEB=3000
HOST_PORT_MINIO_API=9000
HOST_PORT_MINIO_CONSOLE=9001

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VITE_API_BASE_URL=http://localhost:8000
SQLITE_DATABASE_URL=sqlite:////app/data/sqlite/tile-info-platform.db

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# V5：一个项目一个桶，桶内使用前缀区分资源类型。
MINIO_BUCKET=tile-info-platform
MINIO_PREFIX_ORIGINAL=original/
MINIO_PREFIX_THUMBNAILS=thumbnails/
MINIO_PREFIX_PROCESSED=processed/
MINIO_PREFIX_TEMP=tmp/
MINIO_PREFIX_IMPORT=imports/
MINIO_PREFIX_EXPORT=exports/
MINIO_PREFIX_VIDEO=videos/
MINIO_PREFIX_VIDEO_COVER=videos/covers/
MINIO_PREFIX_VIDEO_TRANSCODED=videos/transcoded/

DATA_ROOT=./data
UPLOAD_DIR=/app/data/uploads
PROCESSED_DIR=/app/data/processed
TMP_DIR=/app/data/tmp

VIDEO_ENABLED=true
VIDEO_MAX_SIZE_MB=500
VIDEO_ALLOWED_EXTENSIONS=mp4,mov,m4v,avi,mkv
VIDEO_GENERATE_COVER=true
VIDEO_TRANSCODE_ENABLED=false

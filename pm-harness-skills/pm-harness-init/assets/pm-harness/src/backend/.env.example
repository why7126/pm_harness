# 文档用途：后端服务环境变量示例
# 文档内容：FastAPI、SQLite、MinIO、上传限制、视频处理配置
# 内容来源：AI自动生成，项目团队确认
# 更新方式：后端新增配置时必须同步更新
# 备注：复制为 .env 使用，真实 .env 禁止提交

APP_ENV=development
LOG_LEVEL=INFO
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SQLITE_DATABASE_URL=sqlite:///./data/sqlite/tile_info.db
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_TILE_IMAGES=tile-images
MINIO_BUCKET_TILE_VIDEOS=tile-videos
MINIO_BUCKET_TILE_DOCUMENTS=tile-documents
MINIO_SECURE=false
MAX_IMAGE_SIZE_MB=20
MAX_VIDEO_SIZE_MB=500
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/x-msvideo
VIDEO_PROCESSING_ENABLED=true
VIDEO_TRANSCODE_ENABLED=false
VIDEO_THUMBNAIL_ENABLED=true
APP_SECRET_KEY=change-me-in-local-env
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REMEMBER_ME_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change-me-on-first-run

# ==============================================================================
# {PRODUCT_NAME} - Environment Variables Example
# ==============================================================================
# Copy this file to .env for local development.
# Do not commit real secrets, production credentials, access keys, or tokens.

APP_NAME={PRODUCT_CODE}
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-local-env

# Host ports are configurable to avoid conflicts between local projects.
HOST_PORT_BACKEND=8000
HOST_PORT_WEB=3000
HOST_PORT_MINIO_API=9000
HOST_PORT_MINIO_CONSOLE=9001

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VITE_API_BASE_URL=http://localhost:8000

DATABASE_URL=sqlite:////app/data/sqlite/{PRODUCT_CODE}.db

OBJECT_STORAGE_TYPE=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_SECURE=false
MINIO_BUCKET={PRODUCT_CODE}

DATA_ROOT=./data
UPLOAD_DIR=/app/data/uploads
PROCESSED_DIR=/app/data/processed
TMP_DIR=/app/data/tmp

MEDIA_ENABLED={MEDIA_ENABLED}
MAX_UPLOAD_SIZE_MB=100
